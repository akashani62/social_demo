<div id="<%= dom_id(campaign, :stats) %>" class="grid grid-cols-1 gap-3 sm:grid-cols-4">
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-xs uppercase tracking-wide text-gray-500">Total</p>
    <p class="mt-1 text-2xl font-semibold text-gray-900"><%= campaign.deliveries.count %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-xs uppercase tracking-wide text-gray-500">Pending</p>
    <p class="mt-1 text-2xl font-semibold text-amber-600"><%= campaign.deliveries.pending.count %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-xs uppercase tracking-wide text-gray-500">Sent</p>
    <p class="mt-1 text-2xl font-semibold text-green-600"><%= campaign.deliveries.sent.count %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-xs uppercase tracking-wide text-gray-500">Failed</p>
    <p class="mt-1 text-2xl font-semibold text-red-600"><%= campaign.deliveries.failed.count %></p>
  </div>
</div>
