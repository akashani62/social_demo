<% content_for :title, "New Campaign" %>

<div class="mx-auto max-w-3xl space-y-6">
  <h1 class="text-3xl font-bold tracking-tight text-gray-900">Create sharing campaign</h1>

  <%= form_with model: @campaign, local: true, class: "space-y-6 rounded-2xl border border-gray-200/80 bg-white p-6 shadow-sm ring-1 ring-gray-900/5" do |form| %>
    <div>
      <%= form.label :post_id, "Post", class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :post_id, current_user.posts.order(created_at: :desc), :id, :title_with_author, { prompt: "Select a post" }, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= form.label :recipient_emails, "Recipient emails", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :recipient_emails, rows: 6, required: true, placeholder: "friend1@example.com, friend2@example.com", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
      <p class="mt-1 text-xs text-gray-500">Use commas, semicolons, or new lines.</p>
    </div>

    <div>
      <%= form.label :send_mode, "Send mode", class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :send_mode, Campaign.send_modes.keys.map { |mode| [ mode.humanize, mode ] }, {}, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= form.label :scheduled_at, "Scheduled at (for scheduled mode)", class: "block text-sm font-medium text-gray-700" %>
      <%= form.datetime_local_field :scheduled_at, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>

    <%= form.submit "Create campaign", class: "inline-flex rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500" %>
  <% end %>
</div>
