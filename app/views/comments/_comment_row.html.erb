<%= turbo_frame_tag comment do %>
  <div class="rounded-lg border border-gray-100 bg-gray-50/90 p-4 transition-colors duration-200 hover:bg-white" data-controller="appear">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600"><%= comment.user&.name.presence || "User ##{comment.user_id}" %></p>
        <p class="mt-1 text-sm leading-relaxed text-gray-700 whitespace-pre-wrap"><%= comment.body %></p>
      </div>
      <% if current_user && current_user.id == comment.user_id %>
        <%= button_to "Delete", comment_path(comment), method: :delete,
                      form: { data: { turbo_frame: dom_id(comment), turbo_confirm: "Delete this comment?" } },
                      class: "shrink-0 self-start rounded-md border border-red-200 bg-red-50 px-2.5 py-1 text-xs font-medium text-red-700 hover:bg-red-100" %>
      <% end %>
    </div>
  </div>
<% end %>
