<div class="space-y-4">
  <div class="flex items-start justify-between gap-3">
    <h2 class="text-xl font-semibold tracking-tight text-gray-900">New post</h2>
    <button type="button" class="rounded-md p-1.5 text-gray-500 hover:bg-gray-100 hover:text-gray-900" data-action="modal#close" aria-label="Close">
      <span class="text-xl leading-none" aria-hidden="true">&times;</span>
    </button>
  </div>

  <%= render "form", post: post %>
</div>
