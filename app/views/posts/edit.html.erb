<% content_for :title, "Editing post" %>

<% if turbo_frame_request? %>
  <%= turbo_frame_tag @post do %>
    <div class="rounded-xl border border-gray-200/80 bg-white p-5 shadow-sm ring-1 ring-gray-900/5">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-gray-500">Edit post</h2>
      <%= render "form", post: @post %>
      <div class="mt-4">
        <%= link_to "Cancel", post_path(@post), class: "text-sm font-medium text-gray-600 hover:text-gray-900", data: { turbo_frame: dom_id(@post) } %>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="mx-auto max-w-2xl space-y-6">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Editing post</h1>
    <%= render "form", post: @post %>
    <div class="flex flex-wrap gap-3">
      <%= link_to "Show this post", @post, class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
      <%= link_to "Back to posts", posts_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
    </div>
  </div>
<% end %>
