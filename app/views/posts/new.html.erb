<% content_for :title, "New post" %>

<% if turbo_frame_request? %>
  <%= turbo_frame_tag "new_post_modal" do %>
    <%= render "modal_new_form", post: @post %>
  <% end %>
<% else %>
  <div class="mx-auto max-w-2xl space-y-6">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">New post</h1>
    <%= render "form", post: @post %>
    <%= link_to "Back to posts", posts_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
