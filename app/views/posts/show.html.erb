<% content_for :title, @post.title %>

<div class="mx-auto max-w-3xl space-y-10">
  <% if notice.present? %>
    <p class="rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm font-medium text-green-800" id="notice"><%= notice %></p>
  <% end %>

  <article class="rounded-2xl border border-gray-200/80 bg-white p-8 shadow-sm ring-1 ring-gray-900/5">
    <p class="text-xs font-semibold uppercase tracking-wider text-indigo-600"><%= @post.user&.name.presence || "User ##{@post.user_id}" %></p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-900"><%= @post.title %></h1>
    <div class="prose prose-gray mt-4 max-w-none text-gray-700 whitespace-pre-wrap"><%= @post.body %></div>

    <% if current_user&.id == @post.user_id %>
      <div class="mt-8 flex flex-wrap gap-3 border-t border-gray-100 pt-6">
        <%= link_to "Edit on full page", edit_post_path(@post), class: "rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50", data: { turbo_frame: "_top" } %>
        <%= button_to "Delete post", post_path(@post), method: :delete, class: "rounded-lg border border-red-200 bg-red-50 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-100", data: { turbo_confirm: "Delete this post?" } %>
      </div>
    <% end %>

    <% if current_user %>
      <div class="mt-8 border-t border-gray-100 pt-6">
        <h2 class="text-base font-semibold text-gray-900">Share this post</h2>
        <%= form_with model: Share.new, url: post_shares_path(@post), local: true, class: "mt-3 flex flex-col gap-3 sm:flex-row sm:items-end" do |form| %>
          <div class="w-full sm:max-w-sm">
            <%= form.label :recipient_email, "Recipient email", class: "block text-sm font-medium text-gray-700" %>
            <%= form.email_field :recipient_email, required: true, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
          </div>
          <%= form.submit "Share post", class: "inline-flex rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500" %>
        <% end %>
      </div>
    <% end %>
  </article>

  <section class="rounded-2xl border border-gray-200/80 bg-white p-8 shadow-sm ring-1 ring-gray-900/5" aria-labelledby="comments-heading">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <h2 id="comments-heading" class="text-xl font-semibold tracking-tight text-gray-900">Comments</h2>
      <% if current_user %>
        <div data-controller="modal" data-modal-url-value="<%= new_comment_path(comment: { post_id: @post.id }) %>">
          <button type="button"
                  class="inline-flex rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500"
                  data-action="modal#show">
            Add comment
          </button>
          <dialog data-modal-target="dialog" data-action="click->modal#closeOnBackdrop" class="m-4 w-[min(100%,28rem)] max-h-[min(100%,90vh)] overflow-visible rounded-2xl border-0 bg-transparent p-0 shadow-none">
            <div class="max-h-[85vh] overflow-y-auto rounded-2xl bg-white p-6 shadow-xl ring-1 ring-gray-900/10" data-action="turbo:submit-end->modal#afterSubmit">
              <%= turbo_frame_tag "new_comment_modal", data: { modal_target: "frame" }, class: "block min-h-[1px]" %>
            </div>
          </dialog>
        </div>
      <% else %>
        <%= link_to "Sign in to comment", sign_in_path, class: "text-sm font-semibold text-indigo-600 hover:text-indigo-500" %>
      <% end %>
    </div>

    <%= render "comments/empty_state", blank: @comments.none? %>

    <div id="comments-list" class="mt-6 space-y-4">
      <% @comments.each do |comment| %>
        <%= render partial: "comments/comment_row", locals: { comment: comment } %>
      <% end %>
    </div>
  </section>

  <%= link_to "← Back to posts", posts_path, class: "inline-block text-sm font-medium text-gray-600 hover:text-gray-900" %>
</div>
