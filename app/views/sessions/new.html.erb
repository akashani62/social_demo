<% content_for :title, "Sign in" %>

<div class="mx-auto max-w-lg w-full space-y-6">
  <h1 class="font-bold text-4xl">Sign in</h1>

  <%= form_with url: sign_in_path, scope: :session, local: true, class: "space-y-5" do |form| %>
    <div class="my-5">
      <%= form.label :email %>
      <%= form.email_field :email, autofocus: true, autocomplete: "username", value: params.dig(:session, :email), class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full max-w-md" %>
    </div>

    <div class="my-5">
      <%= form.label :password %>
      <%= form.password_field :password, autocomplete: "current-password", class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full max-w-md" %>
    </div>

    <div class="inline">
      <%= form.submit "Sign in", class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
    </div>
  <% end %>

  <p class="text-gray-600 text-sm">
    Need an account? <%= link_to "Create a user", new_user_path, class: "text-blue-600 hover:underline" %> then sign in here.
  </p>
</div>
